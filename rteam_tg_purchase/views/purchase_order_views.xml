<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_form_tg_approval" model="ir.ui.view">
        <field name="name">purchase.order.form.rteam.tg.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="rteam_tg_has_pending" invisible="1"/>
                <field name="rteam_tg_pending_request_id" invisible="1"/>
                <button name="rteam_tg_open_pending_request"
                        type="object"
                        string="View Telegram approval"
                        icon="fa-telegram"
                        invisible="not rteam_tg_has_pending"/>
            </xpath>
        </field>
    </record>

</odoo>
